. program define _feature_dims, rclass
  1.     version 16.0
  2.     args path
  3.     return scalar rows = .
  4.     return scalar cols = .
  5.     capture confirm file "`path'"
  6.     if (_rc) exit
  7.     capture noisily slab describe "`path'"
  8.     if (_rc == 0) {
  9.         return scalar rows = r(n_rows)
 10.         return scalar cols = r(n_cols)
 11.     }
 12. end

