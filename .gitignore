# ----------------------------------------------------------------------------
# parqit — .gitignore  (C++ / CMake / DuckDB plugin + Stata ado)
# ----------------------------------------------------------------------------

# --- Build output ----------------------------------------------------------
/build/
/cmake-build-*/
/out/
*.o
*.obj
*.lo
*.slo
*.a
*.lib

# --- Compiled Stata plugins / shared libraries -----------------------------
# The per-platform binary is renamed to parqit.plugin only inside release zips,
# so ignore every raw artifact here.
*.plugin
*.so
*.so.*
*.dylib
*.dll
*.pdb
*.exp
*.ilk

# --- CMake ------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
CMakeUserPresets.json
Makefile
compile_commands.json
/_deps/
Testing/

# --- Vendored DuckDB: keep amalgamation sources, ignore its build tree ------
/vendor/duckdb/build/
/extern/duckdb/build/
/third_party/duckdb/build/

# --- Stata / test run artifacts --------------------------------------------
*.smcl
*.log
*.stswp
sysprofile.do.bak
profile.do.bak

# --- Data: never commit datasets of ANY kind; commit small fixtures
#     explicitly under tests/fixtures/ (the !rules below must stay last). ------
# columnar / statistical-package formats
*.parquet
*.feather
*.arrow
*.orc
*.avro
*.dta
*.sav
*.zsav
*.por
*.sas7bdat
*.xpt
*.rds
*.RData
*.rdata
# delimited text / spreadsheets
*.csv
*.tsv
*.psv
*.dat
*.xls
*.xlsx
*.xlsm
*.ods
# array / scientific / serialized
*.h5
*.hdf5
*.nc
*.mat
*.npy
*.npz
*.pkl
*.pickle
*.jsonl
*.ndjson
# version-controlled fixtures are the one exception (keep these last)
!test/fixtures/**
!tests/fixtures/**

# --- Local agent / runner / secrets ----------------------------------------
# Per-machine instructions and runners stay out of version control.
AGENTS.md
GEMINI.md
CLAUDE.local.md
.claude/
# Per-machine scratch: drafts, working notes, private prompts, old logs.
/local/
.env
.env.*
scripts/run-stata.local.*
scripts/*.local.*

# --- Editor / OS ------------------------------------------------------------
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db
/build_done.flag

# --- Repo-local installable ado tree (built artifacts; never commit) -------
/ado/

# --- Local benchmark outputs -----------------------------------------------
/benchmarks/_out/

# --- Distribution artifacts (built zips; shared out-of-band, never commit) --
/dist/
*.zip

# --- Heavy build / fetched archives (DuckDB tarball etc.; refetched, never
#     committed — they bloat the online repo and are rebuilt on demand) -------
*.tar
*.tgz
*.gz
*.bz2
*.xz
*.zst
*.7z
*.rar

# --- Audit-kit scratch (the test pack writes synthetic data + outputs here) --
docs/audits/verifications/**/tests/outputs/
