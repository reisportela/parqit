* ============================================================================
* parqit tour — full functional test + exploration suite over artificial data
*
* Usage:
*   . do parqit_tour.do                       (parqit already installed/adopath'd)
*   . do parqit_tour.do <repo_root> <plugin>  (development tree)
*
* Small synthetic datasets are generated by examples/make_data.py (pyarrow);
* because they are small, a "native twin" is loaded into memory first and
* native Stata computes the oracle for every lazy result we check.
* Every section prints visible exploration output AND asserts correctness.
* ============================================================================
clear all
set more off
set linesize 100
args repo plugin

if (`"`repo'"' != "") {
    adopath ++ `"`repo'/src/ado/p"'
    global PARQIT_PLUGIN_PATH `"`plugin'"'
    local mkdata `"`repo'/examples/make_data.py"'
}
else {
    * installed mode: make_data.py is expected next to this do-file
    local mkdata "make_data.py"
    * if parqit is not on the adopath yet, find the repo-local install tree
    * (this file lives in <repo>/examples, the tree in <repo>/ado/plus/p)
    capture which parqit
    if (_rc) {
        foreach try in "../ado/plus/p" "ado/plus/p" {
            capture confirm file "`try'/parqit.ado"
            if (_rc == 0) {
                adopath ++ "`try'"
                continue, break
            }
        }
    }
    which parqit
}

di as txt _n "{hline 78}"
di as txt "parqit tour — section 0: setup and artificial data"
di as txt "{hline 78}"

parqit version
parqit selftest
assert "`r(selftest)'" == "ok"

capture confirm file workers.parquet
if (_rc) {
    shell python3 "`mkdata'" .
}
confirm file workers.parquet
confirm file firms.parquet
confirm file patents.parquet
confirm file wide_income.parquet
confirm file messy.parquet

