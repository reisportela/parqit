* decorate and write back: labels/notes must survive a parqit round-trip
label variable wage "hourly wage (EUR)"
label define edlbl 1 "basic" 2 "secondary" 3 "tertiary" 4 "phd"
label values education edlbl
note: tour fixture rebuilt by parqit_tour.do
parqit save tour_workers.parquet, replace
parqit use tour_workers.parquet, clear
assert `"`: variable label wage'"' == "hourly wage (EUR)"
assert `"`: label edlbl 3'"' == "tertiary"
assert `"`: char _dta[note1]'"' != ""

* native twin + oracles for everything below
tempfile twin
qui save `"`twin'"'
qui count if missing(wage)
local o_miss = r(N)
qui count if age >= 25 & age <= 54 & !missing(wage)
local o_prime = r(N)
qui summ wage, detail
local o_p50 = r(p50)
local o_kurt = r(kurtosis)
qui correlate wage tenure
local o_rho = r(rho)
qui levelsof region, local(o_regions)
qui duplicates report id
local o_uniq = r(unique_value)
qui count if gender == "F" & education == 3
local o_cell = r(N)
egen byte o_mm = rowmiss(id year wage age gender education region sector ///
    firm_id hours tenure hire_date note)
qui count if o_mm == 0
local o_complete = r(N)
drop o_mm
bysort firm_id: gen long o_fsize = _N
qui summ o_fsize, meanonly
local o_maxfirm = r(max)
drop o_fsize

