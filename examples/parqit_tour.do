* save the in-memory result while the view is still open: data option
gen byte from_memory = 1
parqit save tour_mem.parquet, replace data
* save the (still open) view: default target
parqit save tour_view.parquet, replace
parqit close _all

parqit describe tour_mem.parquet
assert r(n_cols) == 4
parqit describe tour_view.parquet
assert r(n_cols) == 3 & r(n_rows) == `n21'

* open _data: promote memory, aggregate out-of-core, bring it back
clear
set obs 60
gen g = mod(_n, 3)
gen x = _n
parqit open _data, name(mem)
parqit collapse (sum) sx = x, by(g)
parqit collect, clear
assert _N == 3
qui summ sx
assert r(sum) == 60 * 61 / 2
parqit close _all

* chunk(): rows per parquet row group (engine rounds to 2048-multiples)
clear
set obs 10000
gen long rid = _n
parqit save tour_chunked.parquet, replace chunk(2048)
parqit describe tour_chunked.parquet
assert r(n_row_groups) == 5 & r(n_rows) == 10000
capture erase tour_chunked.parquet

* statamissing mode
clear
parqit use using tour_workers.parquet, name(w)
parqit set statamissing on
qui parqit count if wage > 1
local n_stm = r(N)
parqit set statamissing off
qui parqit count if wage > 1
local n_sql2 = r(N)
assert `n_stm' == `n_sql2' + `o_miss'
parqit close _all

