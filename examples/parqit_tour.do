di as txt _n "{hline 78}"
di as txt "section 5: collapse vs native collapse (cell-exact)"
di as txt "{hline 78}"

clear
parqit use using tour_workers.parquet, name(w)
parqit keep if !missing(wage)
parqit collapse (mean) mwage = wage (p50) medwage = wage (count) n = wage, by(region)
parqit sort region
parqit collect, clear
tempfile parqitcol
qui save `"`parqitcol'"'

use `"`twin'"', clear
keep if !missing(wage)
collapse (mean) mwage_o = wage (p50) medwage_o = wage (count) n_o = wage, by(region)
sort region
qui merge 1:1 region using `"`parqitcol'"', assert(match) nogenerate
gen double d1 = reldif(mwage, mwage_o)
gen double d2 = reldif(medwage, medwage_o)
qui summ d1
assert r(max) < 1e-12
qui summ d2
assert r(max) < 1e-12
assert n == n_o
di as txt "collapse: every cell equals native Stata"

