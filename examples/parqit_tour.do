assert reldif(money[1], 12.34) < 1e-12 & missing(money[3])
* duplicate columns both present
assert dup[1] == 100 & dup_1[1] == 7
* null-typed column is an all-missing byte
confirm byte variable allnull
assert missing(allnull[1])

